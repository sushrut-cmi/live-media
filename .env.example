# Copy to .env and fill in.  (mp4_segmenter1.py loads this file directly.)

# ---- Ingest / segmenter ----
# The live stream (or file) URL to segment. When you drive ingest through the
# FastAPI backend (/api/ingest/start), the backend sets this for you and you can
# leave it blank here. Only needed when running mp4_segmenter1.py standalone.
SOURCE_URL=https://d1zg15j6dk79m2.cloudfront.net/live/stream1_1.m3u8
PROTOCOL=hls
SPORT_TYPE=football
# Length of each MP4 chunk, in seconds.
SEGMENT_TIME=30

# ---- AWS Bedrock (Amazon Nova) — used by the Strands agents ----
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=us.amazon.nova-pro-v1:0
# Metadata worker (multimodal video analysis). Must be Nova Lite or Pro (Micro
# is text-only). Lite is cheaper for high-volume per-segment analysis.
BEDROCK_METADATA_MODEL_ID=us.amazon.nova-lite-v1:0
# Max inline video size (MB) sent to Bedrock Converse; larger segments skip.
MAX_INLINE_VIDEO_MB=24

# ---- Localization MCP (Strands localization agent) ----
LOCALIZATION_MCP_URL=http://localhost:8000/sse

# ---- Optional path overrides for highlights_mcp_server.py ----
# DATA_DIR=
# METADATA_PATH=
# VIDEO_DIR=
# HIGHLIGHTS_DIR=
# PERSONA_PATH=
